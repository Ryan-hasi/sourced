{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@sourcedhq/core": ["packages/core/src/index.ts"],
      "@sourcedhq/log": ["packages/log/src/index.ts"],
      "@sourcedhq/conformance": ["packages/conformance/src/index.ts"]
    }
  }
}
