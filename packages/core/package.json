{
  "name": "@sourcedhq/core",
  "version": "0.1.1",
  "description": "The corroboration primitive: how many independent sources corroborate a claim, since when, with receipts. Never 'true' — always 'sourced'.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p ."
  },
  "keywords": [
    "corroboration",
    "verification",
    "sources",
    "news",
    "trust",
    "provenance"
  ],
  "license": "MIT",
  "homepage": "https://sourced.ink",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ryan-hasi/sourced.git",
    "directory": "packages/core"
  }
}
