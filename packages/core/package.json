{
  "name": "@sourcedhq/core",
  "version": "0.1.0",
  "description": "The corroboration primitive: how many independent sources corroborate a claim, since when, with receipts. Never 'true' — always 'sourced'.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ."
  },
  "keywords": [
    "corroboration",
    "verification",
    "sources",
    "news",
    "trust",
    "provenance"
  ],
  "license": "SEE LICENSE IN ../../README.md"
}
