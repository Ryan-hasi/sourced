{
  "name": "@sourcedhq/archive",
  "version": "1.0.0",
  "description": "Persistent event archive for Sourced — the history is the moat. Stores retired events forever for compounding corroboration timelines.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
