  },
  "dependencies": {
    "@sourcedhq/core": "1.0.0"
  },
  "keywords": [
    "corroboration",
    "archive",
    "history",
    "sourced"
  ],
  "license": "MIT",
  "homepage": "https://sourced.ink",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ryan-hasi/sourced.git",
    "directory": "packages/archive"
  }
